# =============================================================================
# Lumea Health Platform - Environment Variables
# =============================================================================
# This is the example configuration file. Copy to .env and fill in your values:
#
#   cp .env.example .env
#
# Required sections are marked [REQUIRED]
# Optional sections can be left empty unless you use that feature
#
# For Docker deployment, copy this file to the root directory as well
# =============================================================================

# =============================================================================
# SECTION 1: DATABASE & AUTHENTICATION [REQUIRED]
# =============================================================================

# PostgreSQL connection string with asyncpg driver
# For Neon (Cloud): postgresql+asyncpg://user:password@host/database?ssl=require
# For Local Dev:    postgresql+asyncpg://user:password@localhost:5432/database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ggwdb

# JWT Secret Key (minimum 32 characters)
# Generate with: openssl rand -hex 32
# MUST change in production!
JWT_SECRET=your-secret-key-change-in-production-min-32-chars

# JWT algorithm (do not change unless you know what you're doing)
JWT_ALGORITHM=HS256

# JWT token expiration in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Frontend origin for CORS validation
# For development: http://localhost:5173
# For production: https://yourdomain.com
FRONTEND_ORIGIN=http://localhost:5173

# =============================================================================
# SECTION 2: AI/LLM PROVIDERS [ONE REQUIRED]
# =============================================================================
# Choose at least ONE LLM provider:
# - Grok API (xAI) - RECOMMENDED, most medical-focused
# - Google Gemini - FREE tier available, good fallback
# - OpenAI - Premium option
# - Ollama - Local/self-hosted option

# ---- GROK API (xAI) - PRIMARY [RECOMMENDED] ----
# Get from: https://console.x.ai/
# Free tier available with 1M tokens/month
GROK_API_KEY=gsk_your_grok_api_key_here
GROK_MODEL=grok-beta

# ---- GOOGLE GEMINI - FALLBACK ----
# Get from: https://aistudio.google.com/apikey
# Free tier: 15 requests/min, 1M tokens/day
# Supported free models: gemini-flash-latest, gemini-1.5-flash-8b
USE_GEMINI_FALLBACK=true
GEMINI_API_KEY=AIzaSy...your_gemini_key_here

# ---- OPENAI - ALTERNATIVE ----
# Get from: https://platform.openai.com/api-keys
# Premium service (paid)
OPENAI_API_KEY=sk_...your_openai_key_here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---- OLLAMA - LOCAL/SELF-HOSTED ----
# Run local: ollama pull medgemma
# For Docker: Use host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=hf.co/unsloth/medgemma-4b-it-GGUF:Q6_K_XL
OLLAMA_TIMEOUT=120
HF_TOKEN=hf_...huggingface_token_for_gated_models

# =============================================================================
# SECTION 3: VOICE AGENT [OPTIONAL] - MULTILINGUAL SUPPORT (EN/HI/MR/GU)
# =============================================================================
# Lumea includes a Voice Agent for hands-free health queries
# Supports: English, Hindi, Marathi, Gujarati
# If TTS not configured, automatically falls back to browser's native TTS

# ---- TEXT-TO-SPEECH (TTS) ----
# ElevenLabs API Key
# Get from: https://elevenlabs.io/ → Settings → API Keys
# Free tier: 10,000 characters/month
# Production use: Subscribe for higher limits
ELEVENLABS_API_KEY=sk_...your_elevenlabs_key_here

# ElevenLabs Voice ID (choose from voice library)
# Rachel (default, female, conversational):        21m00Tcm4TlvDq8ikWAM
# Antoni (male, clear):                            ErXwobaYiN019PkySvjV
# Bella (female, warm):                            EXAVITQu4vr4xnSDxMaL
# See all voices: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Voice generation settings (optional)
# Model: eleven_turbo_v2_5 (free), eleven_turbo_v2, eleven_monolingual_v1
ELEVENLABS_MODEL=eleven_turbo_v2_5

# ---- SPEECH-TO-TEXT (STT) ----
# Uses browser's Web Speech API (no keys needed, works in Chrome/Edge/Safari)
# No configuration required - works automatically

# =============================================================================
# SECTION 4: RAG / VECTOR STORE [OPTIONAL]
# =============================================================================
# ChromaDB for retrieval-augmented generation from user's health history

# ChromaDB persistence directory (absolute path or relative to /app)
CHROMA_PERSIST_DIR=/app/chroma_db

# Embedding model (from Hugging Face)
# all-MiniLM-L6-v2 is small, fast, and good for medical text
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Number of similar documents to retrieve (1-10)
RAG_TOP_K=5

# =============================================================================
# SECTION 5: GOOGLE SERVICES [OPTIONAL]
# =============================================================================

# Google Places API (for pharmacy locator feature)
# Get from: https://console.cloud.google.com/
# Required APIs:
# - Places API
# - Maps JavaScript API
# Free tier: 200 USD/month credit
GOOGLE_PLACES_API_KEY=AIzaSy...your_google_places_key_here

# =============================================================================
# SECTION 6: TWILIO / SMS REMINDERS [OPTIONAL]
# =============================================================================
# For SMS-based health reminders and notifications

# Mode: "mock" (logs only, for testing) or "twilio" (real SMS)
SMS_MODE=mock

# Test phone number (used in mock mode)
SMS_TEST_TO_NUMBER=+919876543210

# Twilio Credentials (required only if SMS_MODE=twilio)
# Get from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+15551234567

# Reminder Settings
REMINDER_SCHEDULER_ENABLED=true
REMINDER_CHECK_INTERVAL_SECONDS=60

# =============================================================================
# SECTION 7: NEO4J GRAPH DATABASE [OPTIONAL]
# =============================================================================
# For knowledge graph storage and Mem0 memory integration
# Supports: Neo4j Community Edition 5.x

# Neo4j Server Connection
# Docker: bolt://neo4j:7687
# Local:  bolt://localhost:7687
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# Memory and Graph Settings
MEM0_COLLECTION=user_memories
GRAPHITI_DATABASE=neo4j

# =============================================================================
# SECTION 8: PULL SETTINGS ON STARTUP [OPTIONAL]
# =============================================================================
# Auto-pull models from Ollama registry

# Enable auto-pull models for Ollama on startup
OLLAMA_PULL_ON_START=false
OLLAMA_PULL_LOG_STEP_PCT=5

# Transformers cache location
TRANSFORMERS_CACHE=/root/.cache/huggingface

# =============================================================================
# FEATURE FLAGS [OPTIONAL]
# =============================================================================

# Use Gemini as fallback when primary LLM unavailable
USE_GEMINI_FALLBACK=true

# Health Profile Requirement (set to false to allow all users)
REQUIRE_HEALTH_PROFILE=false

# =============================================================================
# HOW TO GET API KEYS - QUICK REFERENCE
# =============================================================================
#
# GROK API (xAI):
#   1. Visit https://console.x.ai/
#   2. Sign in or create account
#   3. Create API key
#   4. Copy to GROK_API_KEY
#   Cost: Free tier available (1M tokens/month)
#
# GOOGLE GEMINI:
#   1. Visit https://aistudio.google.com/apikey
#   2. Click "Get API Key"
#   3. Copy to GEMINI_API_KEY
#   Cost: Free tier (15 requests/min, 1M tokens/day)
#
# ELEVENLABS (Voice/TTS):
#   1. Visit https://elevenlabs.io/
#   2. Sign up
#   3. Go to Settings → API Keys
#   4. Copy to ELEVENLABS_API_KEY
#   Cost: Free tier (10,000 chars/month)
#
# GOOGLE PLACES API:
#   1. Visit https://console.cloud.google.com/
#   2. Create new project
#   3. Enable Places API
#   4. Create API key
#   5. Copy to GOOGLE_PLACES_API_KEY
#   Cost: Free tier includes $200/month credit
#
# TWILIO (SMS):
#   1. Visit https://console.twilio.com/
#   2. Create account
#   3. Go to Project Settings
#   4. Copy Account SID, Auth Token, Phone Number
#   Cost: 0.0075 USD per SMS
#
# =============================================================================
# IMPLEMENTATION NOTES
# =============================================================================
#
# VOICE AGENT FEATURES:
# ✓ English (en) - Full support
# ✓ Hindi (hi) - Full support with transliteration
# ✓ Marathi (mr) - Partial support (uses similar script)
# ✓ Gujarati (gu) - Partial support (uses similar script)
# ✓ Mixed/Hinglish - Auto-detected and supported
#
# Functions:
# • Speech-to-Text: Browser Web Speech API (no keys needed)
# • AI Processing: Gemini API (with health context personalization)
# • Text-to-Speech: ElevenLabs TTS or browser native fallback
# • Safety: Emergency detection, dosage inquiry protection
#
# FREE TIER COMPATIBILITY:
# ✓ Gemini API free tier (recommended for development)
# ✓ ElevenLabs 10k chars/month
# ✓ Google Places API $200/month credit
# ✓ Web Speech API (browser native, always free)
#
# =============================================================================
